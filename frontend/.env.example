# Backend API URL (points to mock server in development, real Rust backend in production)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# App base URL — used for Open Graph metadataBase (set to your production domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth v5 — required for OAuth login
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Google OAuth (https://console.cloud.google.com/)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
# Set to "true" once credentials are configured — shows the Google button on the login page
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=

# Apple OAuth (https://developer.apple.com/)
AUTH_APPLE_ID=your-apple-service-id
AUTH_APPLE_SECRET=your-apple-private-key
# Set to "true" once credentials are configured — shows the Apple button on the login page
NEXT_PUBLIC_APPLE_OAUTH_ENABLED=

# Shared secret proving OAuth token-exchange requests come from the Next.js server.
# Generate with: openssl rand -hex 32  — must be identical in backend and frontend.
OAUTH_EXCHANGE_SECRET=your-shared-exchange-secret
